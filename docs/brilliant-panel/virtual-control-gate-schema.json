{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brilliant-mqtt.local/schemas/virtual-control-gate-schema.json",
  "title": "Brilliant Virtual Control feasibility gate ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "records"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gateRecord"
      },
      "maxItems": 6
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,63}$"
        },
        "value": {
          "type": [
            "string",
            "number",
            "integer",
            "boolean"
          ]
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "gateRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "status",
        "recorded_at",
        "summary",
        "evidence"
      ],
      "properties": {
        "gate": {
          "enum": [
            "VC0",
            "VC1",
            "VC2",
            "VC3",
            "VC4",
            "VC5"
          ]
        },
        "status": {
          "enum": [
            "not_run",
            "pass",
            "fail",
            "blocked"
          ]
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      }
    }
  }
}
